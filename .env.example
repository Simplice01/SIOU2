# =============================================================================
# SIOU — Modèle de configuration d'environnement.
#
# Copier ce fichier vers `.env` puis remplir les vraies valeurs :
#     cp .env.example .env
#
# Le vrai `.env` est gitignoré : ne JAMAIS y committer de secrets.
# =============================================================================

# --- Base de données PostgreSQL (Neon + pgvector) ---
# L'application n'utilise que DATABASE_URL. Les variables PG* servent aux outils
# (psql, clients SQL) et sont facultatives pour le backend.
DATABASE_URL=postgresql+asyncpg://utilisateur:motdepasse@hote/nom_base
PGHOST=
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=require
PGCHANNELBINDING=

# --- Sécurité ---
# Chaîne aléatoire longue (ex. : openssl rand -hex 32). Ne pas partager.
JWT_SECRET_KEY=remplacer-par-une-chaine-aleatoire-longue

# --- LLM : génération (API compatible OpenAI ; défaut = Groq) ---
# Clé obligatoire. Créer un compte gratuit sur https://console.groq.com
LLM_API_KEY=gsk_ta_cle_groq_ici
# Surcharges optionnelles (défauts dans backend/core/config.py) :
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_MAX_TOKENS=512
# LLM_TIMEOUT=60

# --- Compte administrateur initial (créé au premier lancement) ---
USERNAME_ADMIN=admin
EMAIL_ADMIN=admin@exemple.bj
PASSWORD_ADMIN=remplacer-par-un-mot-de-passe
ROLE=admin
FIRST_NAME=Prenom
LAST_NAME=Nom
